# Replace every value before the first production deployment.
SITE_DOMAIN=example.com
WORDPRESS_DB_NAME=duola_pocket
WORDPRESS_DB_USER=duola_wp
WORDPRESS_DB_PASSWORD=change-this-wordpress-password
MARIADB_ROOT_PASSWORD=change-this-mariadb-root-password

# Generate unique values at https://api.wordpress.org/secret-key/1.1/salt/
WORDPRESS_AUTH_KEY=replace-with-a-unique-value
WORDPRESS_SECURE_AUTH_KEY=replace-with-a-unique-value
WORDPRESS_LOGGED_IN_KEY=replace-with-a-unique-value
WORDPRESS_NONCE_KEY=replace-with-a-unique-value
WORDPRESS_AUTH_SALT=replace-with-a-unique-value
WORDPRESS_SECURE_AUTH_SALT=replace-with-a-unique-value
WORDPRESS_LOGGED_IN_SALT=replace-with-a-unique-value
WORDPRESS_NONCE_SALT=replace-with-a-unique-value
